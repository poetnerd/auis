#! /bin/sh
set -k
# usage:  mkparser prefix [c-file [h-file]]
#  		where 'prefix' is the name of the grammar.
#	The generated table will have the name prefix_ParseTable (with 
#	'prefix' replaced).
#	The c-file must exist.  If not named in the arguments, its name
#	must be prefix.tab.c.
#	If the h-file is not specified, it is taken to be prefix.tab.h;
#	the h-file need not exist.
#
# Output: files prefix.c and prefix.h suitable for compilation

export prefix
prefix=$1

# determine file names
# c-file
#	$2, if specified, otherwise prefix.tab.c
#	if file does not exist, exit with error
export cfile
cfile=${2-$1.tab.c}
if test \! -r $cfile; then echo Missing .c file: $cfile; exit 3
	else echo Reading $cfile.  Creating ${prefix}.c;  fi
# h-file
#	$3, if specified,otherwise prefix.tab.h
#	if file does not exist, set name to ""
export hfile
hfile=${3-$1.tab.h}
if test \! -r $hfile; then 
	echo Found no .h file.  Creating ${prefix}.h
	hfilename=""
else
	hfilename=$hfile
fi

#generate initial segment of parser declaration in .h file
cat <<EOF > ${prefix}.h
/*  declaration of parser $prefix

	Created by mkparser from  $cfile  $hfilename
*/
#include <cparser.h>

extern struct parser *${prefix}_New();

EOF

#process cfile to produce prefix.c
awkfile=/tmp/makepC$$
trap "rm -f ${awkfile} ${awkfile}.2" 0 1 2 15 

cat<<EOF>$awkfile
BEGIN {
	print "/* produced by mkparser from $cfile */"
	print ""
	print "#include <cparser.h>"
}

# if we see ErrorGuts declared, be sure to call parser_SetErrorFunc
/${prefix}_ErrorGuts.*\(/  {if (sawErrorGuts == 0) {
	sawErrorGuts = 1
}}

# delete bison.simple stuff
# Old bison's #line directives named the skeleton file ('bison.simple')
# while it was being copied in, so this rule could detect "we're now
# inside yyparse() itself" by matching on that filename. Modern bison's
# #line directives only ever reference the generated file itself (e.g.
# "eqparse.tab.c"), never a skeleton filename -- so this never fired,
# and bison's own yyparse() definition (with its un-suppressed opening
# brace) got printed straight through, leaving the 'switch (yyn)' rule
# below injecting reduceActions() while still nested inside it. Trigger
# on the structural marker instead: '#ifdef YYPARSE_PARAM', which always
# opens bison's block of (4, #if/#ifdef-nested) alternate yyparse()
# signatures, through to its single shared opening brace -- all of which
# must be deleted as one unit, preprocessor directives included, since
# deleting only some of those lines would unbalance the #if/#else/#endif
# nesting of whichever ones survive.
/^#ifdef YYPARSE_PARAM/ {deleting = 1}
/#line/ {deleting = 0}
/Note some compilers choke/ {next}
# insert declaration of reduceActions in place of Bison's parser
/switch \(yyn\)/  {
	print ""
	print "#define yyval (*pyyval)"
	print "	static int"
	print "reduceActions(i, pyyval, yyvsp, parser)\nint i;\nYYSTYPE *pyyval;\nYYSTYPE *yyvsp;\n"
	print "		struct parser *parser; {"
	print "	switch (i) {"
	print ""
	# Old bison wrote 'switch (yyn) {' on one line, so matching and
	# discarding just that line was enough. Modern bison puts the brace
	# on its own following line; consume and discard it too, or it
	# leaks through as a third (unwanted) opening brace alongside the
	# two just injected above.
	getline
	deleting = 0
	intables = 0
	next
}

# insert end of reduceActions function
# Old bison's skeleton carried a literal comment here ('the action file
# gets copied in in place of this dollarsign') that survived into its
# generated output as a marker. Modern bison doesn't emit that text at
# all, so the rule never fired -- 'reduceActions' and its enclosing
# 'switch (i) {' were left unclosed, swallowing the rest of bison's own
# yyparse() (and everything after it, including the grammar's epilogue
# code) inside them. Use a structural marker instead, which bison has
# always emitted regardless of version: 'default: break;' immediately
# followed by the switch's own closing brace.
/default: break;/ {
	print
	afterdefault = 1
	next
}
afterdefault == 1 {
	afterdefault = 0
	# This line is bison's own closing brace for 'switch (yyn)' --
	# print it through to close OUR injected 'switch (i) {', then close
	# the injected 'reduceActions(...) {' function with a second brace.
	print "}"
	print " return 0;  /* no special action */"
	print "}"
	print "#undef yyval"
	deleting = 1
	next
}

# Modern bison narrows some tables (yyr1, yyr2, yydefact here; can vary
# by grammar) to yytype_uint8/int8/int16 based on each table's actual
# value range. struct parser_tables casts every one of these tables to
# (short *) uniformly, matching the 1994 bison this engine was written
# for, which always emitted plain 'short'. Reading a uint8 array through
# a short* cast merges two logical 1-byte entries into one bogus 2-byte
# read, silently corrupting any table modern bison happened to narrow
# (confirmed: defred[]/yydefact via this exact bug, for
# ams/libs/ms/prsdate.gra -- a state with a valid default-reduce rule
# read back as rule 0, i.e. "no action", triggering a false syntax error).
# Force the type back to plain 'short' so the width always matches what
# the engine assumes, regardless of which tables modern bison narrows.
/yytype_u?int(8|16|32) yy(r1|r2|defact|pact|pgoto|defgoto|table|check|prhs|rhs|rline)\[\]/ {
	sub(/yytype_u?int(8|16|32)/, "short")
}

# add '#if YYDEBUG != 0' ... '#endif' around  yyprhs, yyrhs, yyrline
#	(but NOT arount yytname)
# This script used to also strip any pre-existing '#if...YYDEBUG' it saw
# near the table declarations, on the assumption that the 1990s bison it
# was written for never guarded that section itself. Modern bison does
# guard it (and guards its own debug-print functions earlier in the file
# with a *different*, real '#if YYDEBUG' too) -- stripping blindly based
# on "have we seen an stdio.h include yet" no longer reliably distinguishes
# the two, and was deleting the opening '#if YYDEBUG' for the debug-print
# functions, leaving their '#else'/'#endif' orphaned and 'yydebug'
# referenced with no declaration in scope. Removed; modern bison's own
# guards are correct as emitted.
/(short yyprhs)|(short yyrhs)|(short yyrline)/ {
	print "#if YYDEBUG != 0"
	print
	inrhsdebug = 1
	next
}
# (continue below)

# delete YYSTYPE declaration
/#ifndef.*YYSTYPE/,/#endif/ {next}

# pass through all lines not handled above
{if (deleting == 0) {print}}

# (continuation of wrapping rhs stuff with #if YYDEBUG ...)
/};/ {if (inrhsdebug == 1) {print "#endif"; inrhsdebug = 0}}

# at end, append the table and class declaration
END {
	print "#line 119 \"mkparser\""
	print ""
	print "static struct parser_tables ${prefix}_ParseTable = {"
	print "	YYNTOKENS,	/* num_tokens */"
	print "	YYNNTS,		/* num_nt */"
	print "	YYMAXUTOK,	/* max_user_token */"
	print "	YYNRULES,	/* num_rules */"
	print "	YYNSTATES,	/* num_states */"
	print "	YYFINAL,	/* final_state */"
	print ""
	print "	sizeof(YYSTYPE),	/* eltsz */"
	print ""
	print "	YYPACT_NINF,	/* defflag -- old bison called this YYFLAG;"
	print "			   modern bison renamed it but it's the same"
	print "			   sentinel (\"no pact entry, use default"
	print "			   reduction\") that actx[]/yypact[] uses */"
	print "	YYTABLE_NINF,	/* tblflag -- table[]'s own \"no valid entry\""
	print "			   sentinel. Distinct from YYPACT_NINF in modern"
	print "			   bison (one shared value in the old bison this"
	print "			   engine was written for); conflating them lets"
	print "			   a real table[] entry get misread as an error,"
	print "			   or vice versa. */"
	print "	YYLAST,		/* table_max */"
	print ""
	print "	(char **)yytname,	/* name */"
	print "	(char *)yytranslate,	/* translate */"
	print ""
	print "	(short *)yyr1,		/* lhs */"
	print "#if YYDEBUG != 0"
	print "	(short *)yyprhs,	/* rhsx */"
	print "	(short *)yyr2,		/* rhssz */"
	print "	(short *)yyrhs,		/* rhs */"
	print "#else"
	print "	(short *)NULL,		/* rhsx */"
	print "	(short *)yyr2,		/* rhssz */"
	print "	(short *)NULL,		/* rhs */"
	print "#endif"
	print "	(short *)yytable,	/* table */"
	print "	(short *)yycheck,	/* valid */"
	print ""
	print "	(short *)yydefact,	/* defred */"
	print "	(short *)yypact,	/* actx */"
	print "	(short *)yydefgoto,	/* defnext */"
	print "	(short *)yypgoto, 	/* nextx */"
	print "	(parser_semfptr)reduceActions	/* actions */"
	print "};"
	print ""
	print "struct parser *${prefix}_New() {"
	print "	struct parser *self=parser_New();"
	print "	parser_SetTables(self, &${prefix}_ParseTable);"
	if (sawErrorGuts) {
		print "	parser_SetErrorFunc(self, (parser_errfptr)${prefix}_ErrorGuts);"
	}
	print "	return self;"
	print "}"
}
EOF
awk -f $awkfile $cfile > ${prefix}.c

if  test -r $hfile; then 
	echo Reading $hfile.  Creating ${prefix}.h

	#process hfile to make prefix.h
	cat<<EOF>$awkfile.2
		#terminate class declaration
		BEGIN {
			print ""
		}
		# delete YYSTYPE declaration
		/#ifndef.*YYSTYPE/,/#endif/ {next}
		# delete declaration of yylval
		/yylval/ {next}
		# otherwise, just copy the whole thing
		{print}
EOF
	awk -f $awkfile.2 $hfile >> ${prefix}.h
fi
rm -f $awkfile $awkfile.2

