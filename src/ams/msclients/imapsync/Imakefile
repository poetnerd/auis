/* imapsync -- one-way IMAP-to-local-store mirror.
   ANSI C (C89 prototypes), linked directly against libmssrv the way
   ams/msclients/nns does, plus libmail.a for imap_prot.o/tlscon.o/
   netrc.o/genid.o.

   NOTE: imapsync deliberately does NOT link libcui.a/libcuin.a the way
   cui does.  It calls no CUI_ function anywhere -- only MS_ calls, on
   fully-qualified absolute paths (see the module comment in
   imap_sync.c) -- so it is modeled on nns/Imakefile's simpler
   direct-libmssrv link line instead. Tried linking libcui.a/libcuin.a
   first (matching cui's NOSNAPLIBS literally); it fails: cuilib.o
   needs interactive UI
   callback hooks (ReportError, GetStringFromUser, SetTerminalParams,
   Interactive, ChooseFromList, DirectoryChangeHook,
   SubscriptionChangeHook) that only a full terminal client like cui.c/
   cuifns.c/andmchs.o implements, and imapsync -- a one-shot batch tool
   with no interactive UI -- has no use for CUI_'s caching/disambiguation
   layer in the first place. */

LOCALINCLUDES	=	-I${BASEDIR}/include/ams

OBJS = imap_sync.o

LIBS = ${BASEDIR}/lib/libmail.a $(BASEDIR)/lib/libcparser.a ${BASEDIR}/lib/liberrors.a \
			${MALLOCLIB} ${UTILLIB}

NOSNAPLIBS	= ${BASEDIR}/lib/libmssrv.a ${BASEDIR}/lib/libmsshr.a \
			${BASEDIR}/lib/libeli.a ${BASEDIR}/lib/librxp.a \
			${LIBS}	${PRSLIB}

NormalObjectRule()

ProgramTarget(imapsync, ${OBJS}, ${NOSNAPLIBS}, ${MMDFLIBS} $(LEXLIB) ${BSDLIB} ${SSLLIB} ${RESOLVER_LIB})

InstallProgram(imapsync, $(DESTDIR)/bin)

DependTarget()
