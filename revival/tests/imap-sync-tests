# ---- direct .MS_MsgDir snapshot decoding (read-only; independent of
# cui/CUI_ so case 4's flag check isn't just re-trusting imapsync's own
# apply_flags code path through a second layer of itself) ----
#
# Fixed-width record layout (ams/libs/hdrs/ams.h): date(7) + caption(89)
# + chain(4) + midhash(4) + replyhash(4) + attributes(21) + id(19) = 148
# bytes/record, records start at byte 1024+148=1172 in .MS_MsgDir.
_DATESIZE, _CAPTIONSIZE, _CHAINSIZE, _MIDHASHSIZE, _REPLYHASHSIZE, _ATTRSIZE, _IDSIZE = 7, 89, 4, 4, 4, 21, 19
_CAPTOFF = _DATESIZE
_CHAINOFF = _CAPTOFF + _CAPTIONSIZE
_MIDOFF = _CHAINOFF + _CHAINSIZE
_REPLYOFF = _MIDOFF + _MIDHASHSIZE
_ATTROFF = _REPLYOFF + _REPLYHASHSIZE
_IDOFF = _ATTROFF + _ATTRSIZE
_SNAPSIZE = _IDOFF + _IDSIZE
_DIRHEADSIZE = 1024 + _SNAPSIZE
_AMS_ATT_DELETED = 2
_AMS_ATT_UNSEEN = 6
_AMS_ATT_REPLIEDTO = 12


def _has_attr(attrbytes, bitno):
    return bool(attrbytes[bitno // 8] & (1 << (bitno % 8)))


def read_snapshots(root):
    """Returns {id: {"caption": str, "unseen": bool, "replied": bool,
    "deleted": bool}} decoded directly from .MS_MsgDir."""
    path = msgdir_path(root)
    out = {}
    with open(path, "rb") as f:
        data = f.read()
    n = (len(data) - _DIRHEADSIZE) // _SNAPSIZE
    for i in range(n):
        rec = data[_DIRHEADSIZE + i * _SNAPSIZE: _DIRHEADSIZE + (i + 1) * _SNAPSIZE]
        ident = rec[_IDOFF:_IDOFF + 18].decode(errors="replace")
        caption = rec[_CAPTOFF:_CAPTOFF + _CAPTIONSIZE].split(b"\x00")[0].decode(errors="replace")
        attrs = rec[_ATTROFF:_ATTROFF + _ATTRSIZE]
        out[ident] = {
            "caption": caption,
            "unseen": _has_attr(attrs, _AMS_ATT_UNSEEN),
            "replied": _has_attr(attrs, _AMS_ATT_REPLIEDTO),
            "deleted": _has_attr(attrs, _AMS_ATT_DELETED),
        }
    return out


# ---- writeback (Gate 2) cases W2/W3/W4/W7: folder-parametrized path
# helpers, journal fabrication, and the write-mailbox guard ----

def assert_write_mailbox(folder):
    """The one enforcement point every writeback helper below funnels
    through -- refuses, at the Python level, to run anything destructive
    against any folder but WRITE_MAILBOX. Independent of imaptest.c's
    own guard_mailbox(), which enforces the identical rule at the C
    level for create/storeflags/expunge/append -- a safety rule this
    important should not have exactly one enforcement point."""
    if folder != WRITE_MAILBOX:
        sys.exit(f"imap-sync-tests: REFUSING a writeback-case call against folder {folder!r} "
                 f"-- only {WRITE_MAILBOX!r} is allowed for writeback (Gate 2) cases")


def run_imapsync_wb(root, folder, extra_args=(), timeout=120):
    assert_write_mailbox(folder)
    return subprocess.run([IMAPSYNC, "-root", root, "-folders", folder, "-v", *extra_args],
                          capture_output=True, text=True, timeout=timeout)


def imaptest_wb(subcmd, folder, *rest, timeout=60):
    """Runs a destructive (create/storeflags/expunge/append)
    imaptest.test subcommand, guarded the same way run_imapsync_wb()
    is. Returns (CompletedProcess, kv dict) like imap-protocol-tests'
    own imaptest()/parse_kv() helpers."""
    assert_write_mailbox(folder)
    r = subprocess.run([IMAPTEST, subcmd, HOST, PORT, NETRC, MACHINE, folder] + [str(a) for a in rest],
                        capture_output=True, text=True, timeout=timeout)
    kv = {}
    for line in r.stdout.splitlines():
        if ": " in line:
            k, v = line.split(": ", 1)
            m = re.match(r'^(-?\d+)\s*\(', v.strip())
            kv[k.strip()] = m.group(1) if m else v.strip()
    return r, kv


def imaptest_readonly(subcmd, folder, *rest, timeout=60):
    """Like imaptest_wb but for read-only subcommands (examine,
    fetchflags) that take a folder/mailbox argument -- no guard, since
    these never write, but kept as a separate name so it's obvious at
    each call site whether the guard is in play."""
    r = subprocess.run([IMAPTEST, subcmd, HOST, PORT, NETRC, MACHINE, folder] + [str(a) for a in rest],
                        capture_output=True, text=True, timeout=timeout)
    kv = {}
    for line in r.stdout.splitlines():
        if ": " in line:
            k, v = line.split(": ", 1)
            m = re.match(r'^(-?\d+)\s*\(', v.strip())
            kv[k.strip()] = m.group(1) if m else v.strip()
    return r, kv


