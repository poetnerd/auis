_BASE32HEX = "0123456789ABCDEFGHIJKLMNOPQRSTUV"


def encode_base32hex7(v):
    """Python mirror of imap_sync.c's encode_base32hex7() -- used only
    to fabricate a deliberately-WRONG-UIDVALIDITY id for case W7; every
    other case reads real ids back from the mirror's own body-file
    names rather than re-deriving them, so this isn't load-bearing for
    the id format itself."""
    return "".join(_BASE32HEX[(v >> ((6 - i) * 5)) & 0x1F] for i in range(7))


def synth_id_py(uidvalidity, uid):
    return "IMAP" + encode_base32hex7(uidvalidity) + encode_base32hex7(uid)


ATTRSIZE = 21


def hexmask(bytelist):
    return "".join("%02x" % b for b in bytelist)


def or_mask_for_bit(bit):
    """The OrMask/AndMask a real ASS_OR_ATTRIBUTES call setting `bit`
    would produce (see altsnap.c's writeback-capture switch, and
    imap-writeback-tests' identical helper): or-mask has just that bit
    set, and-mask is all-1s -- forces the bit ON regardless of the
    server's prior value."""
    ormask = [0] * ATTRSIZE
    ormask[bit // 8] |= (1 << (bit % 8))
    andmask = [0xff] * ATTRSIZE
    return hexmask(ormask), hexmask(andmask)


def and_mask_clearing_bit(bit):
    """The OrMask/AndMask a real ASS_AND_ATTRIBUTES call clearing `bit`
    would produce: or-mask all-0s, and-mask all-1s except the cleared
    bit -- forces the bit OFF regardless of the server's prior value."""
    ormask = [0] * ATTRSIZE
    andmask = [0xff] * ATTRSIZE
    andmask[bit // 8] &= ~(1 << (bit % 8)) & 0xff
    return hexmask(ormask), hexmask(andmask)


