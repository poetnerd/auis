def send_marker(tmpdir, tag):
    """Sends a plaintext marker message to SEND_RECIPIENT via the
    committed SMTP dropoff path, using a scratch PROFILES (smtphost
    only -- smtpnetrc left unset so it falls through to the real
    ~/.netrc, exactly as smtp-protocol-tests' live cases do). Returns
    the exact subject line sent, for later matching."""
    subject = f"{SUBJECT_MARKER} incremental probe {tag}"
    msgfile = os.path.join(tmpdir, "marker.txt")
    profile = os.path.join(tmpdir, "profile_smtp")
    date = time.strftime("%a, %d %b %Y %H:%M:%S %z")
    with open(msgfile, "w", newline="\n") as f:
        f.write(
            f"From: {SEND_RECIPIENT}\n"
            f"To: {SEND_RECIPIENT}\n"
            f"Subject: {subject}\n"
            f"Date: {date}\n"
            f"\n"
            f"imap-sync-tests incremental-sync probe message.\n"
            f"Marker: {SUBJECT_MARKER}\n"
            f"Tag: {tag}\n"
        )
    with open(profile, "w", newline="\n") as f:
        f.write("smtphost: smtp.fastmail.com\nsmtpport: 465\n")

    env = dict(os.environ)
    env["PROFILES"] = profile
    r = subprocess.run([SMTPTEST, msgfile, SEND_RECIPIENT], capture_output=True, text=True,
                        env=env, timeout=60)
    ok = r.returncode == 0 and "D_OK" in r.stdout
    return ok, subject, r.stdout + r.stderr


def poll_sync_for_subject(root, subject, attempts=18, interval=10):
    """Re-runs imapsync against root repeatedly until a body file
    containing `subject` shows up, tolerant of delivery delay. Returns
    (found_path_or_None, last_run_result)."""
    last = None
    for attempt in range(1, attempts + 1):
        last = run_imapsync(root)
        hits = find_marker_files(root, subject)
        if hits:
            return hits[0], last
        note(f"poll {attempt}/{attempts}: marker not synced yet, waiting {interval}s")
        time.sleep(interval)
    return None, last


# ---- case 6: cui browse, pty-driven (pattern from revival/tools/smtp-send-test) ----

class CuiSession:
    def __init__(self, profiles_path, timeout=20.0):
        import pty
        self.timeout = timeout
        master, slave = pty.openpty()
        self.master = master
        env = dict(os.environ)
        env["PROFILES"] = profiles_path
        self.proc = subprocess.Popen([CUI], stdin=slave, stdout=slave, stderr=slave,
                                      close_fds=True, env=env)
        os.close(slave)
        self.buf = b""

    def _fill(self, idle=0.3):
        import select
        r, _, _ = select.select([self.master], [], [], idle)
        if self.master in r:
            try:
                chunk = os.read(self.master, 4096)
            except OSError:
                return False
            if not chunk:
                return False
            self.buf += chunk
        return True

    def expect_any(self, patterns, timeout=None):
        timeout = self.timeout if timeout is None else timeout
        deadline = time.time() + timeout
        while time.time() < deadline:
            for p in patterns:
                if p in self.buf:
                    self.buf = b""
                    return p
            if not self._fill():
                return None
        return None

    def send(self, text):
        os.write(self.master, text.encode())

    def collect(self, t=3):
        """Drain output for t seconds and return everything seen."""
        deadline = time.time() + t
        out = b""
        while time.time() < deadline:
            before = len(self.buf)
            self._fill(idle=0.3)
            out += self.buf[before:] if len(self.buf) >= before else b""
        collected = out
        self.buf = b""
        return collected

    def close(self):
        if self.proc.poll() is None:
            try:
                self.proc.terminate()
                self.proc.wait(timeout=3)
            except Exception:
                self.proc.kill()


def since_cutoff_for_marker(raw_body_text, fallback_days=30):
    """Derives a cui "since <date>" cutoff (format cui's MS_ParseDate/
    parsedate accepts, e.g. "17-Jul-2026") one day before the marker
    message's own Date: header, so `headers <dir> since <date>` shows
    only a small tail of the mailbox around the marker instead of
    however many thousand older messages the real INBOX holds. Falls
    back to `fallback_days` before now if the Date: header is missing
    or unparseable, which still narrows things down enormously versus
    no filter at all."""
    date_line = next((l for l in raw_body_text.splitlines() if l.lower().startswith("date:")), "")
    when = None
    if date_line:
        try:
            when = email.utils.parsedate_to_datetime(date_line.split(":", 1)[1].strip())
        except (TypeError, ValueError):
            when = None
    if when is None:
        when = datetime.datetime.now(datetime.timezone.utc) - datetime.timedelta(days=fallback_days)
    cutoff = when - datetime.timedelta(days=1)
    return cutoff.strftime("%d-%b-%Y")


def cui_browse_check(root, marker_subject, since_date, timeout=30.0):
    """Points cui's mspath at the scratch mirror via a scratch PROFILES
    file (never ~/preferences), lists INBOX, and reads the marker
    message. Returns (listed_ok, subject_in_headers, subject_in_body,
    transcript).

    Uses "headers <dir> since <date>" rather than a bare "headers
    <dir>": cui assigns each message its session-local display number
    (cuid) in the order first encountered, not its absolute position in
    the mailbox, so restricting the initial listing to a `since` window
    keeps the marker's display number small and keeps the listing to a
    handful of screens instead of however many thousand messages the
    real mailbox holds. The listing can still span more than one
    "-- More --" screen (e.g. other mail landed the same day), so this
    pages through every screen before giving up on finding the marker,
    exactly like the body-reading loop below already does."""
    if not os.path.isfile(CUI):
        return False, False, False, f"cui binary not found at {CUI}"

    profiles_path = os.path.join(root, "PROFILES")
    with open(profiles_path, "w", newline="\n") as f:
        f.write(f"mspath: {os.path.join(root, '.MESSAGES')}\n")

    transcript = []
    sess = CuiSession(profiles_path, timeout=timeout)
    try:
        if sess.expect_any([b"CUI> "]) is None:
            return False, False, False, "cui did not print its startup prompt (CUI>)"

        sess.send(f"headers {MAILBOX} since {since_date}\n")
        time.sleep(1.0)
        headers_text = ""
        sent_pages = 0
        headers_deadline = time.time() + max(timeout, 90.0)
        while time.time() < headers_deadline:
            chunk = sess.collect(t=1)
            headers_text += chunk.decode(errors="replace")
            more_count = headers_text.count("-- More --")
            if more_count > sent_pages:
                sess.send("\n")
                sent_pages = more_count
                continue
            if headers_text.rstrip().endswith("CUI> "):
                break
        transcript.append(headers_text)
        subject_in_headers = marker_subject[:26] in headers_text or SUBJECT_MARKER in headers_text

        # Find the message number next to the marker line.
        msgnum = None
        for line in headers_text.splitlines():
            if SUBJECT_MARKER in line:
                m = re.match(r"\s*(\d+)\s", line)
                if m:
                    msgnum = m.group(1)
                break

        subject_in_body = False
        if msgnum is not None:
            sess.send(f"type {msgnum}\n")
            # Real delivered mail (including our own self-sent marker,
            # once Fastmail's LMTP delivery attaches its usual ARC/DKIM/
            # spam-score headers) can run many pager screens before the
            # marker text scrolls into view -- poll in short bursts, page
            # on every "-- More --" seen, and give this one message a
            # generous overall budget (independent of the per-prompt
            # `timeout` used elsewhere in this session).
            body_text = ""
            sent_pages = 0
            body_deadline = time.time() + max(timeout, 90.0)
            while time.time() < body_deadline:
                chunk = sess.collect(t=1)
                body_text += chunk.decode(errors="replace")
                if SUBJECT_MARKER in body_text:
                    break
                # One space per "-- More --" screen seen so far -- counting
                # cumulative occurrences (rather than testing only the
                # latest chunk, or testing for the prompt at the very end
                # of the buffer) survives the prompt text arriving split
                # across reads.
                more_count = body_text.count("-- More --")
                if more_count > sent_pages:
                    sess.send("\n")  # the prompt's own text: "Press Enter to continue"
                    sent_pages = more_count
                    continue
                if body_text.rstrip().endswith("CUI> "):
                    break
            transcript.append(body_text)
            subject_in_body = SUBJECT_MARKER in body_text

        sess.send("quit\n")
        transcript.append(sess.collect(t=2).decode(errors="replace"))
        return True, subject_in_headers, subject_in_body, "\n".join(transcript)
    finally:
        sess.close()


def main():
    if len(sys.argv) > 1:
        sys.exit("usage: imap-sync-tests")

    build_imaptest()
    build_imapsync()
    build_smtptest()

    live = have_live_credentials()
    if not live:
        note(f'--- no usable netrc stanza for "{MACHINE}" in "{NETRC}" (or file absent); '
             "skipping all cases (this suite has no offline case) ---")
        for n in ("1 fresh mirror of INBOX", "2 idempotent re-run", "3 incremental sync",
                  "4 flags mapping", "5 UIDVALIDITY change drill", "6 cui browse",
                  "W2 flags round-trip", "W3 purge round-trip", "W4 safety valve",
                  "W7 stale-journal drill"):
            skip(n, "no live credentials")
        note("")
        note(f"{len(PASS)} passed, {len(FAIL)} failed, {len(SKIP)} skipped "
             f"(live cases skipped: no usable netrc credentials for {MACHINE})")
        sys.exit(0)

    note(f"--- live cases against {HOST}:{PORT}, mailbox {MAILBOX} (strictly read-only from imapsync) ---")

    scratch = tempfile.mkdtemp(prefix="imap-sync-tests-")
    note(f"scratch root: {scratch}")
    try:
        exists = examine_exists()
        if exists is None:
            sys.exit("imap-sync-tests: could not independently EXAMINE INBOX for a ground-truth count")
        note(f"EXAMINE INBOX (ground truth, independent of imapsync): EXISTS={exists}")

        # ---- case 1: fresh mirror ----
        r1 = run_imapsync(scratch)
        note(r1.stdout)
        if r1.stderr:
            note(r1.stderr)

        local_count = count_body_files(scratch)
        count_ok = local_count == exists
        result("1a fresh mirror: local message count matches EXAMINE's EXISTS",
               r1.returncode == 0 and count_ok,
               f"imapsync exit={r1.returncode} local_count={local_count} EXISTS={exists}")

        marker_hits = find_marker_files(scratch)
        if not marker_hits:
            skip("1b spot-check marker message (STAGE-3-CUI-TEST)",
                 f"no message with subject/body containing {SUBJECT_MARKER!r} found in the mirror -- "
                 "expected: a previous run's case 3 will leave one, or run smtp-send-test first")
        else:
            marker_path = marker_hits[0]
            marker_id = os.path.basename(marker_path)[1:]  # strip leading '+'
            id_ok = bool(ID_RE.match(marker_id))
            snaps = read_snapshots(scratch)
            caption_ok = marker_id in snaps and SUBJECT_MARKER in snaps[marker_id]["caption"]
            body_readable = False
            try:
                with open(marker_path, "rb") as f:
                    body_readable = SUBJECT_MARKER.encode() in f.read()
            except OSError:
                pass
            result("1b spot-check marker message (STAGE-3-CUI-TEST): "
                   "caption present, body file readable, id has the documented synthesized format",
                   id_ok and caption_ok and body_readable,
                   f"id={marker_id!r} id_ok={id_ok} caption_ok={caption_ok} body_readable={body_readable}")

        # ---- case 2: idempotency ----
        # A live mailbox can grow between case 1's fresh mirror and this
        # re-run -- that is not a failure of imapsync's idempotency, it's
        # new mail genuinely arriving. So instead of asserting the naive
        # "nothing changed" (which false-fails on exactly that race), this
        # bounds the re-run with an independent ground-truth EXAMINE on
        # each side and asserts two things a race can't explain away:
        # (1) nothing already-mirrored was removed or renamed (a true
        # idempotency violation would show up here regardless of new
        # mail), and (2) the local growth is fully accounted for by
        # genuinely new server uids in that same window, not by
        # imapsync duplicating or re-adding anything.
        pre_size = os.path.getsize(msgdir_path(scratch)) if os.path.isfile(msgdir_path(scratch)) else -1
        pre_count = count_body_files(scratch)
        pre_files = body_files(scratch)
        exists_before_r2 = examine_exists()

        r2 = run_imapsync(scratch)
        note(r2.stdout)
        if r2.stderr:
            note(r2.stderr)

        post_size = os.path.getsize(msgdir_path(scratch)) if os.path.isfile(msgdir_path(scratch)) else -1
        post_count = count_body_files(scratch)
        post_files = body_files(scratch)
        exists_after_r2 = examine_exists()

        removed_files = pre_files - post_files
        added_files = post_files - pre_files
        expected_growth = (
            exists_after_r2 - exists_before_r2
            if exists_before_r2 is not None and exists_after_r2 is not None
            else None
        )
        growth_explained = expected_growth is not None and len(added_files) == expected_growth
        result("2 idempotent re-run: alters nothing already-mirrored, and any local growth "
               "is exactly accounted for by genuinely new server uids since the fresh mirror",
               r2.returncode == 0 and not removed_files and post_size >= pre_size and growth_explained,
               f"exit={r2.returncode} pre_size={pre_size} post_size={post_size} "
               f"pre_count={pre_count} post_count={post_count} removed={len(removed_files)} "
               f"added={len(added_files)} exists_before={exists_before_r2} exists_after={exists_after_r2} "
               f"expected_growth={expected_growth}")

        # ---- case 3: incremental sync ----
        before_files = body_files(scratch)
        sendtag = str(int(time.time()))
        sent_ok, marker_subject, send_log = send_marker(scratch, sendtag)
        if not sent_ok:
            result("3 incremental sync: send marker + poll-sync until it appears", False,
                   f"smtptest.test send failed: {send_log}")
            skip("4 flags mapping", "case 3's send failed; nothing to check")
        else:
            new_path, r3 = poll_sync_for_subject(scratch, marker_subject)
            note(r3.stdout if r3 else "(no imapsync run captured)")
            if r3 and r3.stderr:
                note(r3.stderr)
            after_files = body_files(scratch)
            added = after_files - before_files
            new_marker_id = os.path.basename(new_path)[1:] if new_path else None
            result("3 incremental sync: exactly one new message added, and it is the marker",
                   new_path is not None and len(added) == 1 and (os.path.basename(new_path) in added),
                   f"new_path={new_path!r} added={added!r}")

            # ---- case 4: flags mapping ----
            if new_marker_id is None:
                skip("4 flags mapping", "case 3's marker never synced; nothing to check")
            else:
                snaps = read_snapshots(scratch)
                new_unseen_ok = new_marker_id in snaps and snaps[new_marker_id]["unseen"] is True
                # An "old" message: anything from the case-1 mirror (not the
                # just-added marker) that the server already shows read.
                old_seen_ok = False
                old_example = None
                for ident, rec in snaps.items():
                    if ident == new_marker_id:
                        continue
                    if rec["unseen"] is False:
                        old_seen_ok = True
                        old_example = ident
                        break
                result("4 flags mapping: newly-arrived message has AMS_ATT_UNSEEN set; "
                       "an old, server-seen message does not",
                       new_unseen_ok and old_seen_ok,
                       f"new_marker_id={new_marker_id} new_unseen={snaps.get(new_marker_id, {}).get('unseen')} "
                       f"old_example={old_example} old_seen_ok={old_seen_ok}")

        # ---- case 5: UIDVALIDITY change drill ----
        sp = statepath(scratch)
        real_uidvalidity = None
        if os.path.isfile(sp):
            with open(sp) as f:
                for line in f:
                    if line.startswith("uidvalidity "):
                        real_uidvalidity = line.split()[1].strip()
                        break
        if real_uidvalidity is None:
            skip("5 UIDVALIDITY change drill", "could not read the current .MS_IMAPSync uidvalidity")
        else:
            lines = open(sp).read().splitlines()
            corrupted = ["uidvalidity 1" if l.startswith("uidvalidity ") else l for l in lines]
            with open(sp, "w", newline="\n") as f:
                f.write("\n".join(corrupted) + "\n")

            r5 = run_imapsync(scratch)
            note(r5.stdout)
            if r5.stderr:
                note(r5.stderr)
            loud = "UIDVALIDITY changed" in r5.stdout or "UIDVALIDITY changed" in r5.stderr

            exists_after = examine_exists()
            final_count = count_body_files(scratch)
            final_uidvalidity = None
            if os.path.isfile(sp):
                with open(sp) as f:
                    for line in f:
                        if line.startswith("uidvalidity "):
                            final_uidvalidity = line.split()[1].strip()
                            break
            result("5 UIDVALIDITY change drill: corrupting the state file triggers a loud re-mirror, "
                   "final state is correct",
                   r5.returncode == 0 and loud and final_uidvalidity == real_uidvalidity
                   and exists_after is not None and final_count == exists_after,
                   f"loud={loud} final_uidvalidity={final_uidvalidity} real_uidvalidity={real_uidvalidity} "
                   f"final_count={final_count} exists_after={exists_after}")

        # ---- case 6: cui browse ----
        marker_hits = find_marker_files(scratch)
        if not marker_hits:
            skip("6 cui browse", "no marker message present in the mirror to look for")
        else:
            with open(marker_hits[0], "rb") as f:
                body = f.read().decode(errors="replace")
            subj_line = next((l for l in body.splitlines() if l.lower().startswith("subject:")), "")
            since_date = since_cutoff_for_marker(body)
            note(f"cui browse: using \"headers {MAILBOX} since {since_date}\" to keep the marker's "
                 "display number small instead of paging the whole mailbox")
            listed_ok, subj_in_headers, subj_in_body, transcript = cui_browse_check(scratch, subj_line, since_date)
            note("--- cui transcript ---")
            note(transcript)
            result("6 cui browse: cui lists the folder and displays the marker's caption and body",
                   listed_ok and subj_in_headers and subj_in_body,
                   f"listed_ok={listed_ok} subj_in_headers={subj_in_headers} subj_in_body={subj_in_body}")
    finally:
        if os.environ.get("IMAPSYNC_KEEP_SCRATCH"):
            note(f"IMAPSYNC_KEEP_SCRATCH set; leaving scratch root at {scratch}")
        else:
            shutil.rmtree(scratch, ignore_errors=True)

    # ---- writeback (Gate 2) cases W2/W3/W4/W7 -- own scratch root and
    # mailbox (WRITE_MAILBOX), entirely independent of the INBOX mirror
    # above; see the module docstring for the fabricated-journal
    # testing rationale and the guard rule. ----
    wb_scratch = tempfile.mkdtemp(prefix="imap-sync-tests-wb-")
    note(f"writeback scratch root: {wb_scratch}")
    try:
        cr, ckv = imaptest_wb("create", WRITE_MAILBOX)
        if cr.returncode not in (0, 1) or ckv.get("CREATE-RC") not in ("0", "1"):
            sys.exit(f"imap-sync-tests: could not create/confirm {WRITE_MAILBOX!r}: kv={ckv}")

        wtag = str(int(time.time()))

        # ---- case W2: flags round-trip ----
        uv2, uid2 = append_test_message(WRITE_MAILBOX, f"GATE2-W2-FLAGS-{wtag}", wb_scratch, f"w2-{wtag}")
        if uv2 is None:
            result("W2 flags round-trip", False, "append_test_message failed to produce a uid")
        else:
            rmir = run_imapsync_wb(wb_scratch, WRITE_MAILBOX)
            note(rmir.stdout)
            if rmir.stderr:
                note(rmir.stderr)
            hits = find_marker_files_for(wb_scratch, WRITE_MAILBOX, f"GATE2-W2-FLAGS-{wtag}")
            if not hits:
                result("W2 flags round-trip", False, "message did not mirror locally after append")
            else:
                id2 = os.path.basename(hits[0])[1:]
                # Force AMS_ATT_UNSEEN off (the ASS_AND_ATTRIBUTES path,
                # exactly what CUI_MarkAsRead's own OrMask/AndMask pair
                # would produce) -- replay must map that to adding \Seen.
                ormask_hex, andmask_hex = and_mask_clearing_bit(_AMS_ATT_UNSEEN)
                write_journal_lines(wb_scratch, WRITE_MAILBOX, [f"J1 flags {id2} {ormask_hex} {andmask_hex}"])

                r_replay = run_imapsync_wb(wb_scratch, WRITE_MAILBOX)
                note(r_replay.stdout)
                if r_replay.stderr:
                    note(r_replay.stderr)

                _, fkv = imaptest_readonly("fetchflags", WRITE_MAILBOX, uid2)
                seen_pushed = fkv.get("FOUND") == "yes" and "\\Seen" in fkv.get("FLAGS", "")

                journal_gone = (not os.path.exists(journalpath_for(wb_scratch, WRITE_MAILBOX))
                                 and not os.path.exists(replayingpath_for(wb_scratch, WRITE_MAILBOX)))
                cursor_zero = True
                sp2 = statepath_for(wb_scratch, WRITE_MAILBOX)
                if os.path.isfile(sp2):
                    with open(sp2) as f:
                        cursor_zero = "journal_offset 0" in f.read()

                r_noop = run_imapsync_wb(wb_scratch, WRITE_MAILBOX)
                noop_ok = (r_noop.returncode == 0
                           and not os.path.exists(journalpath_for(wb_scratch, WRITE_MAILBOX)))

                result("W2 flags round-trip: replay pushes \\Seen, verified via a real IMAP FLAGS "
                       "fetch; journal consumed and cursor zeroed; a second replay run is a no-op",
                       r_replay.returncode == 0 and seen_pushed and journal_gone and cursor_zero and noop_ok,
                       f"seen_pushed={seen_pushed} fkv={fkv} journal_gone={journal_gone} "
                       f"cursor_zero={cursor_zero} noop_ok={noop_ok}")

        # ---- case W3: purge round-trip ----
        uv3, uid3 = append_test_message(WRITE_MAILBOX, f"GATE2-W3-PURGE-{wtag}", wb_scratch, f"w3-{wtag}")
        if uv3 is None:
            result("W3 purge round-trip", False, "append_test_message failed to produce a uid")
        else:
            rmir = run_imapsync_wb(wb_scratch, WRITE_MAILBOX)
            note(rmir.stdout)
            if rmir.stderr:
                note(rmir.stderr)
            hits = find_marker_files_for(wb_scratch, WRITE_MAILBOX, f"GATE2-W3-PURGE-{wtag}")
            if not hits:
                result("W3 purge round-trip", False, "message did not mirror locally after append")
            else:
                id3 = os.path.basename(hits[0])[1:]
                # Simulate what MS_PurgeDeletedMessages itself would
                # already have done locally (unlink the body file) --
                # replay only pushes the removal to the server, it never
                # touches local body files, so the local side of "purge
                # locally" has to be done here explicitly to get a
                # meaningful "count consistent" check below.
                os.remove(hits[0])
                write_journal_lines(wb_scratch, WRITE_MAILBOX, [f"J1 purge {id3}"])

                r_replay = run_imapsync_wb(wb_scratch, WRITE_MAILBOX)
                note(r_replay.stdout)
                if r_replay.stderr:
                    note(r_replay.stderr)

                _, fkv = imaptest_readonly("fetchflags", WRITE_MAILBOX, uid3)
                gone_server_side = fkv.get("FOUND") == "no"

                _, ekv3 = imaptest_readonly("examine", WRITE_MAILBOX)
                server_exists = int(ekv3["EXISTS"]) if ekv3.get("EXISTS", "").isdigit() else None
                local_count = len(body_files_for(wb_scratch, WRITE_MAILBOX))
                count_consistent = server_exists is not None and server_exists == local_count

                result("W3 purge round-trip: purge locally (fabricated record), replay, uid gone "
                       "server-side (verified via a real FETCH), local mirror count consistent "
                       "with the server's EXISTS after the same run's mirror pass",
                       r_replay.returncode == 0 and gone_server_side and count_consistent,
                       f"gone_server_side={gone_server_side} server_exists={server_exists} "
                       f"local_count={local_count}")

        # ---- case W4: safety valve ----
        _, ekv4 = imaptest_readonly("examine", WRITE_MAILBOX)
        uidvalidity4 = int(ekv4["UIDVALIDITY"]) if ekv4.get("UIDVALIDITY", "").isdigit() else 0
        fake_lines = [f"J1 purge {synth_id_py(uidvalidity4, 900000 + i)}" for i in range(26)]
        write_journal_lines(wb_scratch, WRITE_MAILBOX, fake_lines)

        r_refuse = run_imapsync_wb(wb_scratch, WRITE_MAILBOX)
        note(r_refuse.stdout)
        if r_refuse.stderr:
            note(r_refuse.stderr)
        loud_refused = ("over the safety valve" in r_refuse.stdout
                         or "over the safety valve" in r_refuse.stderr)
        replaying_path4 = replayingpath_for(wb_scratch, WRITE_MAILBOX)
        still_pending = os.path.isfile(replaying_path4)
        sp4 = statepath_for(wb_scratch, WRITE_MAILBOX)
        cursor_untouched = True
        if os.path.isfile(sp4):
            with open(sp4) as f:
                cursor_untouched = "journal_offset 0" in f.read()

        # Bonus, folded into this same case rather than a separate
        # numbered one: -force-purges overrides the refusal and clears
        # the (fabricated, all-nonexistent-uid) journal cleanly.
        r_force = run_imapsync_wb(wb_scratch, WRITE_MAILBOX, extra_args=("-force-purges",))
        note(r_force.stdout)
        if r_force.stderr:
            note(r_force.stderr)
        forced_cleared = (r_force.returncode == 0
                          and not os.path.isfile(replaying_path4)
                          and not os.path.isfile(journalpath_for(wb_scratch, WRITE_MAILBOX)))

        result("W4 safety valve: 26 fabricated purges refused without -force-purges (journal "
               "left untouched, cursor still 0, for a later run to resume); -force-purges "
               "overrides and clears it",
               r_refuse.returncode != 0 and loud_refused and still_pending and cursor_untouched
               and forced_cleared,
               f"loud_refused={loud_refused} still_pending={still_pending} "
               f"cursor_untouched={cursor_untouched} forced_cleared={forced_cleared} "
               f"refuse_exit={r_refuse.returncode} force_exit={r_force.returncode}")

        # ---- case W7: stale-journal / UIDVALIDITY-mismatch drill ----
        uv7, uid7 = append_test_message(WRITE_MAILBOX, f"GATE2-W7-STALE-{wtag}", wb_scratch, f"w7-{wtag}")
        if uv7 is None:
            result("W7 stale-journal drill", False, "append_test_message failed to produce a uid")
        else:
            rmir = run_imapsync_wb(wb_scratch, WRITE_MAILBOX)
            note(rmir.stdout)
            if rmir.stderr:
                note(rmir.stderr)
            wrong_uidvalidity = uv7 + 1  # guaranteed different from the folder's real UIDVALIDITY
            stale_id = synth_id_py(wrong_uidvalidity, uid7)
            write_journal_lines(wb_scratch, WRITE_MAILBOX, [f"J1 purge {stale_id}"])

            r_stale = run_imapsync_wb(wb_scratch, WRITE_MAILBOX)
            note(r_stale.stdout)
            if r_stale.stderr:
                note(r_stale.stderr)
            loud_stale = ("stale UIDVALIDITY" in r_stale.stdout
                          or "stale UIDVALIDITY" in r_stale.stderr)

            journal_gone7 = (not os.path.exists(journalpath_for(wb_scratch, WRITE_MAILBOX))
                              and not os.path.exists(replayingpath_for(wb_scratch, WRITE_MAILBOX)))

            # A stale entry is SKIPPED, not acted on -- the real message
            # (a genuinely different, correctly-mirrored uid) must still
            # be present server-side afterward.
            _, fkv7 = imaptest_readonly("fetchflags", WRITE_MAILBOX, uid7)
            still_present = fkv7.get("FOUND") == "yes"

            result("W7 stale-journal drill: a journal entry whose id has the wrong UIDVALIDITY "
                   "is skipped with the loud log line, the cursor still advances past it "
                   "(journal fully consumed), and the real message is untouched",
                   r_stale.returncode == 0 and loud_stale and journal_gone7 and still_present,
                   f"loud_stale={loud_stale} journal_gone7={journal_gone7} still_present={still_present}")

        # Best-effort tidiness, not a test case: leave WRITE_MAILBOX
        # empty afterward rather than accumulating this run's test
        # messages (W2's own \Seen message in particular is never
        # purged by any case above) across repeated suite runs.
        _, ekv_clean = imaptest_readonly("examine", WRITE_MAILBOX)
        if ekv_clean.get("EXISTS", "0").isdigit() and int(ekv_clean["EXISTS"]) > 0:
            r_clean, ckv_clean = imaptest_wb("expunge", WRITE_MAILBOX, "1:*")
            note(f"writeback cleanup: expunge 1:* in {WRITE_MAILBOX!r} -> "
                 f"exit={r_clean.returncode} kv={ckv_clean}")
    finally:
        if os.environ.get("IMAPSYNC_KEEP_SCRATCH"):
            note(f"IMAPSYNC_KEEP_SCRATCH set; leaving writeback scratch root at {wb_scratch}")
        else:
            shutil.rmtree(wb_scratch, ignore_errors=True)

    note("")
    note(f"{len(PASS)} passed, {len(FAIL)} failed, {len(SKIP)} skipped")
    sys.exit(1 if FAIL else 0)


if __name__ == "__main__":
    main()
