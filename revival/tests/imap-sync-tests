def append_test_message(folder, subject, tmpdir, tag):
    """APPENDs a small message with the given subject into folder via
    imap_Append (imaptest.test's append subcommand), returning
    (uidvalidity, uid) from the APPENDUID response code, or (None,
    None) on failure."""
    bodyfile = os.path.join(tmpdir, f"append-{tag}.eml")
    with open(bodyfile, "wb") as f:
        f.write(
            f"Date: {time.strftime('%a, %d %b %Y %H:%M:%S %z')}\r\n"
            f"From: wdc@fastmail.com\r\n"
            f"To: wdc@fastmail.com\r\n"
            f"Subject: {subject}\r\n"
            f"\r\n"
            f"imap-sync-tests writeback-case probe message ({tag}).\r\n"
        .encode())
    r, kv = imaptest_wb("append", folder, bodyfile)
    if r.returncode != 0 or kv.get("APPEND-RC") != "0":
        return None, None
    uv = kv.get("APPEND-UIDVALIDITY")
    uid = kv.get("APPEND-UID")
    if uv is None or uid is None:
        return None, None
    return int(uv), int(uid)


